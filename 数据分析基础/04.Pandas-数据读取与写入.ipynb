    "import pandas as pd\n",
    "\n",
    "#读取数据\n",
    "\n",
    "#1.读取全部数据\n",
    "# df=pd.read_csv(\"data/sales.csv\")\n",
    "# df\n",
    "\n",
    "#2.读取其中几列\n",
    "df=pd.read_csv(\"data/sales.csv\",usecols=[\"订单号\",\"产品类别\",\"产品名称\",\"销售数量\",\"单价\"])\n",
    "# df\n",
    "\n",
    "# 数据处理\n",
    "df[\"销售额\"]=df[\"销售数量\"]*df[\"单价\"]\n",
    "# df\n",
    "\n",
    "# 写入数据\n",
    "df.to_csv(\"data/sales_01.csv\",index=False)\n"
